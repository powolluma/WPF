<Window x:Class="CalculatorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculatorWPF"
        mc:Ignorable="d"
        Title="Калькулятор" Height="450" Width="800">
    <Grid>
        <!--Поля ввода и вывода-->
        <TextBox x:Name="Expression" HorizontalAlignment="Left" Margin="309,112,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="135"  Height="17"/>
        <TextBox x:Name="Result" HorizontalAlignment="Left" Margin="309,134,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="135"/>
        
        <!--Кнопки-->
        <Button Content="CE" HorizontalAlignment="Left" Margin="309,173,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="C" HorizontalAlignment="Left" Margin="344,173,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="&lt;" HorizontalAlignment="Left" Margin="379,173,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="/" HorizontalAlignment="Left" Margin="414,173,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="7" HorizontalAlignment="Left" Margin="309,208,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="8" HorizontalAlignment="Left" Margin="344,208,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="9" HorizontalAlignment="Left" Margin="379,208,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="*" HorizontalAlignment="Left" Margin="414,208,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="4" HorizontalAlignment="Left" Margin="309,243,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="5" HorizontalAlignment="Left" Margin="344,243,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="6" HorizontalAlignment="Left" Margin="379,243,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="-" HorizontalAlignment="Left" Margin="414,243,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="1" HorizontalAlignment="Left" Margin="309,278,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="2" HorizontalAlignment="Left" Margin="344,278,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="3" HorizontalAlignment="Left" Margin="379,278,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="+" HorizontalAlignment="Left" Margin="414,278,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="." HorizontalAlignment="Left" Margin="309,313,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="0" HorizontalAlignment="Left" Margin="344,313,0,0" VerticalAlignment="Top" Height="30" Width="30" Click="Button_Click"/>
        <Button Content="=" HorizontalAlignment="Left" Margin="379,313,0,0" VerticalAlignment="Top" Height="30" Width="65" Click="Button_Click"/>

    </Grid>
</Window>
