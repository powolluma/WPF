<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Главное окно" Height="500" Width="700">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Создать XML" Width="150" Height="35" Click="CreateXml_Click"/>
            <Button Content="Читать XmlDocument" Width="150" Height="35" Margin="10,0" Click="ReadDocument_Click"/>
            <Button Content="Читать XmlTextReader" Width="160" Height="35" Click="ReadReader_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <TextBlock x:Name="tbResult" 
                       TextWrapping="Wrap" 
                       FontSize="13"
                       Padding="10"
                       Background="#F0F0F0"/>
        </ScrollViewer>
    </Grid>
</Window>