<Window x:Class="KeyboardTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клавиатурный тренажёр" Height="780" Width="1200"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyUp="Window_KeyUp">

    <Grid Margin="20">
        <!--Разметка-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Статистика -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Скорость:" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock x:Name="tbSpeed" Text="0 chars/min" FontSize="16" Margin="10,0" VerticalAlignment="Center"/>
            <TextBlock Text="Ошибки:" FontSize="14" Margin="30,0,0,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="tbFails" Text="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            <CheckBox x:Name="cbCaseSensitive" Content="Учитывать регистр" Margin="50,0,0,0" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>

        <!--Длина текста, запуск и остановка программы-->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Длина текста:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <Slider x:Name="slDifficulty" Minimum="10" Maximum="70" Value="30" Width="200" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Value, ElementName=slDifficulty}" Margin="12,0" VerticalAlignment="Center" FontSize="14"/>
            <Button x:Name="btnStart" Content="Начать" Width="120" Height="40" Margin="60,0,0,0" Click="BtnStart_Click" FontSize="14"/>
            <Button x:Name="btnStop" Content="Стоп" Width="120" Height="40" Margin="12,0,0,0" IsEnabled="False" Click="BtnStop_Click" FontSize="14"/>
        </StackPanel>

        <!-- Текст для набора -->
        <TextBlock x:Name="tbTargetText" Grid.Row="2" FontSize="23" FontFamily="Consolas" TextWrapping="Wrap" Background="#F5F5F5" Padding="20" Margin="0,0,0,20"/>

        <!-- Клавиатура -->
        <StackPanel x:Name="KeyboardGrid" Grid.Row="4" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
    </Grid>
</Window>